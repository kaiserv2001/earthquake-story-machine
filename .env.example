# Copy to .env for local development: cp .env.example .env
# .env is gitignored — never commit real secrets.

# SQL Server SA password used by the mssql, servicebus-sql, and servicebus-emulator
# containers in docker-compose.yml. Must satisfy SQL Server complexity rules:
# 8+ chars, with upper, lower, digit, and symbol.
MSSQL_SA_PASSWORD=LocalDev_Passw0rd!
